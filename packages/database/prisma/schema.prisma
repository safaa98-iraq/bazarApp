generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  MERCHANT
  CUSTOMER
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  role            Role     @default(CUSTOMER)
  name            String
  plan            Plan     @default(FREE)
  planChangedAt   DateTime?
  whatsapp        String?  @db.VarChar(20)
  googleId        String?  @unique @db.VarChar(128)
  isActive        Boolean  @default(true)
  aiRequestLimit  Int      @default(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store           Store?
  orders          Order[]
  carts           Cart[]
  adminLogs       AdminLog[]
  aiUsageLogs     AIUsageLog[]
  paymentRequests PaymentRequest[]
  notifications   Notification[]

  @@index([email])
  @@index([role])
}

model Store {
  id              String   @id @default(cuid())
  merchantId      String   @unique
  name            String
  slug            String   @unique
  description     String?  @db.Text
  logo            String?
  theme           String   @default("#6366f1")
  template        String   @default("minimal")
  isActive        Boolean  @default(true)
  isPublished     Boolean  @default(false)
  widgetEnabled   Boolean  @default(false)
  widgetDomains   Json     @default("[]")
  widgetTheme     String   @default("light") @db.VarChar(50)
  widgetRateLimit Int      @default(100)
  builderConfig   String?  @db.LongText
  storeType       String   @default("general") @db.VarChar(50)
  currency        String   @default("SAR") @db.VarChar(10)
  suspendedAt     DateTime?
  suspendReason   String?  @db.VarChar(255)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  merchant       User           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  products       Product[]
  categories     Category[]
  orders         Order[]
  carts          Cart[]
  adminLogs      AdminLog[]
  storeAnalytics StoreAnalytics[]
  widgetEvents   WidgetEvent[]
  coupons        Coupon[]
  productAttributes ProductAttribute[]
  banners           StoreBanner[]

  @@index([slug])
  @@index([merchantId])
}

model WidgetEvent {
  id        String   @id @default(cuid())
  storeId   String
  type      String   @db.VarChar(50)
  sessionId String?
  ip        String?  @db.VarChar(45)
  meta      Json?
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([type])
  @@index([createdAt])
}

model Category {
  id      String @id @default(cuid())
  storeId String
  name    String
  slug    String

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([storeId, slug])
  @@index([storeId])
}

model Product {
  id             String   @id @default(cuid())
  storeId        String
  name           String
  description    String?  @db.Text
  price          Decimal  @db.Decimal(10, 2)
  comparePrice   Decimal? @db.Decimal(10, 2)
  images         Json     @default("[]")
  stock          Int      @default(0)
  categoryId     String?
  isActive       Boolean  @default(true)
  seoTitle       String?
  seoDescription String?  @db.Text
  seoSlug        String?
  unitType       String   @default("piece") @db.VarChar(20)
  unitLabel      String   @default("قطعة") @db.VarChar(30)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems   OrderItem[]
  cartItems    CartItem[]
  productViews ProductView[]
  attributeValues ProductAttributeValue[]

  @@index([storeId])
  @@index([categoryId])
}

model Order {
  id              String      @id @default(cuid())
  storeId         String
  customerId      String?
  customerEmail   String
  customerName    String
  total           Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  shippingAddress Json
  stripePaymentId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  store    Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@index([storeId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model Cart {
  id         String   @id @default(cuid())
  customerId String?
  storeId    String
  sessionId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer User?      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store    Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@unique([customerId, storeId])
  @@index([sessionId, storeId])
  @@index([customerId])
  @@index([storeId])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  productId String
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  details    Json?
  storeId    String?
  createdAt  DateTime @default(now())

  admin User   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([storeId])
}

model AIUsageLog {
  id         String   @id @default(cuid())
  merchantId String
  feature    String
  tokensUsed Int      @default(0)
  cost       Decimal  @default(0) @db.Decimal(10, 6)
  inputHash  String?
  createdAt  DateTime @default(now())

  merchant User @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([feature])
  @@index([createdAt])
}

model StoreAnalytics {
  id             String   @id @default(cuid())
  storeId        String
  date           DateTime @db.Date
  pageViews      Int      @default(0)
  uniqueVisitors Int      @default(0)
  revenue        Decimal  @default(0) @db.Decimal(10, 2)
  ordersCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@index([storeId])
  @@index([date])
}

model ProductView {
  id         String   @id @default(cuid())
  productId  String
  customerId String?
  sessionId  String
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sessionId])
  @@index([createdAt])
}

model Coupon {
  id             String    @id @default(cuid())
  storeId        String
  affiliateId    String?   @db.VarChar(191)
  code           String    @db.VarChar(50)
  label          String?   @db.VarChar(191)
  discountType   String    @default("percent") @db.VarChar(20)
  discountValue  Decimal   @db.Decimal(10, 2)
  minOrderAmount Decimal?  @db.Decimal(10, 2)
  maxUses        Int?
  usedCount      Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, code])
  @@index([storeId])
  @@index([code])
}

model Affiliate {
  id             String    @id
  storeId        String    @db.VarChar(191)
  name           String
  email          String?
  phone          String?   @db.VarChar(50)
  platform       String?   @db.VarChar(50)
  handle         String?
  followerCount  Int?
  commissionType String    @default("percent") @db.VarChar(20)
  commissionRate Decimal   @default(10) @db.Decimal(10, 2)
  totalEarned    Decimal   @default(0) @db.Decimal(12, 2)
  totalOrders    Int       @default(0)
  isActive       Boolean   @default(true)
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversions AffiliateConversion[]

  @@index([storeId])
}

model AffiliateConversion {
  id               String   @id
  affiliateId      String   @db.VarChar(191)
  storeId          String   @db.VarChar(191)
  couponId         String   @db.VarChar(191)
  orderId          String?  @db.VarChar(191)
  orderTotal       Decimal  @db.Decimal(12, 2)
  discountAmount   Decimal  @default(0) @db.Decimal(12, 2)
  commissionAmount Decimal  @default(0) @db.Decimal(12, 2)
  createdAt        DateTime @default(now())

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@index([affiliateId])
  @@index([storeId])
  @@index([couponId])
}

model ProductAttribute {
  id           String   @id @default(cuid())
  storeId      String
  name         String   @db.VarChar(100)
  kind         String   @default("select") @db.VarChar(20) // select | text | number | color | boolean
  options      Json     @default("[]") // for kind=select/color: string[]
  isRequired   Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  store  Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  values ProductAttributeValue[]

  @@index([storeId])
}

model ProductAttributeValue {
  id          String @id @default(cuid())
  productId   String
  attributeId String
  value       String @db.VarChar(500)

  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
  @@index([productId])
}

model PaymentRequest {
  id          String   @id @default(cuid())
  userId      String
  planTarget  String   @db.VarChar(20)
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("IQD") @db.VarChar(10)
  status      String   @default("PENDING") @db.VarChar(20)
  txRef       String?  @db.VarChar(255)
  proofUrl    String?  @db.VarChar(500)
  adminNote   String?  @db.Text
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  body      String   @db.Text
  meta      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model StoreBanner {
  id        String   @id @default(cuid())
  storeId   String
  title     String
  subtitle  String?
  imageUrl  String?
  linkUrl   String?
  bgColor   String   @default("#432E54") @db.VarChar(30)
  textColor String   @default("#ffffff") @db.VarChar(30)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

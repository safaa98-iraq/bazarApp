# Google Sign-In — get Client ID from https://console.cloud.google.com
# Authorized origins: http://localhost:3000  (add your production domain too)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Google AdSense — shown on FREE plan storefronts only
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT=1234567890
NEXT_PUBLIC_AD_DELAY_MS=8000
NEXT_PUBLIC_AD_INTERVAL_MS=180000
